# Notion integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token_here

# 32-character database ID from the Notion database URL
NOTION_DATABASE_ID=your_notion_database_id_here

# Base URL for sitemap generation — use your Vercel domain in production
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# OpenAI API key — required for AI summaries in new-issue.js
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Admin password for the /admin page — change this to something secure
ADMIN_PASSWORD=changeme

# Secret token for the /capture page and /api/capture endpoint.
# Keep this separate from ADMIN_PASSWORD — safe to use in iOS Shortcuts
# and bookmarklets since it only grants article-capture access.
CAPTURE_TOKEN=your_capture_token_here

# Auto-injected by Vercel for cron jobs. Set manually for local testing.
# Used to authenticate /api/cron/daily-publish.
CRON_SECRET=your_cron_secret_here

# Optional: configures the "Import from briefing" admin panel.
# JSON array of { id, label, type, dateProperty? } objects.
#
#   type: "page"     — id points to a parent page whose child pages are dated
#                      daily briefings (e.g. "Daily Briefing (2026-04-25)")
#   type: "database" — id points to a database; today's row is found by
#                      filtering on the date property (default "Date",
#                      override with dateProperty)
#
# Each daily entry's body is parsed for articles (h2 sections + bulleted items
# with embedded links). Leave empty/unset to hide the panel.
# Example with all three:
# BRIEFING_SOURCES=[{"id":"344fe201077b80b89f1df7a8f62df15f","label":"Canada AI Daily","type":"page"},{"id":"439d19d541754e49a955f0c1c67607af","label":"Agriculture AI","type":"database"},{"id":"cc85c149325540bca9fa0ba4a3006d46","label":"Daily News - AI","type":"database"}]
BRIEFING_SOURCES=
