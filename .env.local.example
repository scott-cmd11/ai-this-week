# Notion integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_integration_token_here

# 32-character database ID from the Notion database URL
NOTION_DATABASE_ID=your_notion_database_id_here

# Base URL for sitemap generation — use your Vercel domain in production
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# OpenAI API key — required for AI summaries in new-issue.js
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Admin password for the /admin page — change this to something secure
ADMIN_PASSWORD=changeme
